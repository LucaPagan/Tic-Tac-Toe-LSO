<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import java.lang.String?>

<VBox fx:id="root" alignment="CENTER" fillWidth="true"
      prefHeight="560.0" prefWidth="480.0"
      spacing="20"
      styleClass="game-root"
      xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tristrick.client.gui.GameController">

    <stylesheets>
        <String fx:value="/tristrick/client/styles.css" />
    </stylesheets>

    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <!-- ═══ Game Title ═══ -->
    <VBox alignment="CENTER" spacing="2">
        <Label text="⊞ TRIS" styleClass="game-title" />
        <Label text="PARTITA IN CORSO" styleClass="game-subtitle" />
    </VBox>

    <!-- ═══ Status Bar ═══ -->
    <HBox alignment="CENTER" spacing="10.0">
        <Label fx:id="statusLabel" text="Attendi l'avversario..." />
    </HBox>

    <!-- ═══ Game Board ═══ -->
    <GridPane fx:id="gameBoard" alignment="CENTER"
              hgap="10.0" vgap="10.0" styleClass="game-board">
        <Button fx:id="cell00" text="" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="cell-button" />
        <Button fx:id="cell01" text="" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="cell-button" />
        <Button fx:id="cell02" text="" GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="cell-button" />
        <Button fx:id="cell10" text="" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="cell-button" />
        <Button fx:id="cell11" text="" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="cell-button" />
        <Button fx:id="cell12" text="" GridPane.columnIndex="2" GridPane.rowIndex="1" styleClass="cell-button" />
        <Button fx:id="cell20" text="" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="cell-button" />
        <Button fx:id="cell21" text="" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="cell-button" />
        <Button fx:id="cell22" text="" GridPane.columnIndex="2" GridPane.rowIndex="2" styleClass="cell-button" />
    </GridPane>

    <!-- ═══ Back Button (initially hidden) ═══ -->
    <HBox alignment="CENTER" spacing="10.0">
        <padding>
            <Insets top="8" />
        </padding>
        <Button fx:id="backButton" text="← Torna alla Home"
                visible="false" onAction="#handleBackButton" />
    </HBox>

</VBox>